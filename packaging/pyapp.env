# pyapp.env — env-variables, которые ``cargo install pyapp`` читает при сборке.
#
# Это НЕ файл для запуска приложения — это конфигурация *сборки* PyApp
# launcher-а.  Использование:
#
#   set -a; source packaging/pyapp.env; set +a
#   cargo install pyapp --root dist --force
#
# Документация: https://ofek.dev/pyapp/latest/config/

# ── Что это за приложение ────────────────────────────────────────────────────
PYAPP_PROJECT_NAME=pa-clean
PYAPP_PROJECT_VERSION=1.0.0-pilot

# Какой entry-point запускать.  В PyApp 0.29 EXEC_SPEC формата
# "module:function" — единственный способ задать вызов функции;
# EXEC_MODULE отдельно не нужен (тогда PyApp бы запускал `python -m
# module` без аргумента).
#
# ВАЖНО: модуль ДОЛЖЕН быть внутри ``personal_assistant`` package — иначе
# в venv его нет (wheel pa-clean ставит только src/personal_assistant/).
# Раньше указывали ``packaging.entrypoint`` — там name-collision с реальным
# PyPI-пакетом ``packaging`` (от PyPA, тянется pip-ом), → ImportError при
# первом запуске бандла.
PYAPP_EXEC_SPEC=personal_assistant.app_launcher:main

# ── Источник Python: standalone-distribution ─────────────────────────────────
# python-build-standalone, версия Python, target = macOS arm64.
#
# 3.13 — потому что `mlx-lm` 0.30+ публикует wheels ТОЛЬКО для cp313 (см. CI
# инцидент: pip --python-version=3.12 не нашёл mlx==0.31.x).  uv генерит lock
# против локального Python, который у нас сейчас 3.13 → выравниваем.
#
# Вариант python-build-standalone (install_only_stripped vs full) выбирается
# PyApp 0.29 автоматически по платформе; раньше можно было задать через
# PYAPP_DISTRIBUTION_VARIANT, но в 0.29 этой переменной больше нет —
# попытка её установить интерпретируется как URL источника и build.rs
# падает с «Unable to determine format for distribution source».
PYAPP_PYTHON_VERSION=3.13

# ── Phase 1: bootstrap deps from PyPI на первом запуске ──────────────────────
#
# Раньше пытались запекать все wheels в бинарь через
# ``PYAPP_PROJECT_DEPENDENCY_FILE`` + ``--no-deps``.  Не сработало:
# PyApp 0.29 встраивал dep-файл криво (rustc-env показывало пустой
# ``PYAPP_PROJECT_DEPENDENCY_FILE=``), а ``--no-deps`` блокировал
# установку транзитивных зависимостей по METADATA wheel-а — итог:
# venv без ``uvicorn``, ``fastapi``, ``mlx-lm``, бандл падает на
# первом импорте.
#
# Phase 1 решение: PyApp подкачивает зависимости из PyPI при первом
# запуске через wheel-метаданные pa-clean.  Требует доступа к PyPI у
# пилота на bootstrap (~1-2 минуты, ~500 MB).  Phase 2 — добавление
# offline-wheelhouse через ``PYAPP_PIP_EXTERNAL=true`` +
# ``--find-links``, см. PILOT_DISTRIBUTION.md.
#
# Файл packaging/requirements-pyapp.txt всё равно генерируется как
# побочный артефакт build_pilot.sh — пригодится в Phase 2 для
# offline-варианта.

# ВНИМАНИЕ: НЕ ставим PYAPP_PROJECT_DEPENDENCY_FILE и не
# PYAPP_PIP_EXTRA_ARGS=--no-deps — иначе venv будет без транзитивов.

# ── Поведение пользователя ───────────────────────────────────────────────────
# Куда раскладывать venv первого запуска.  По умолчанию ~/.cache/pyapp.
PYAPP_FULL_ISOLATION=true

# Показывать прогресс установки при первом запуске.
PYAPP_PASS_LOCATION=true
PYAPP_EXPOSE_METADATA=true

# ── Self-update mechanism ────────────────────────────────────────────────────
# PyApp поддерживает self-update через PyPI или GitHub Releases.  Включаем
# команду ``self update``, тестировщики смогут получать патчи без
# переустановки .dmg.  Для пилота можно подкрутить custom-endpoint позже —
# сейчас работаем с git-tag-ом.
PYAPP_SELF_COMMAND=true
PYAPP_UPGRADE_VIRTUALENV=true
