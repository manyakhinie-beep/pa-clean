# =============================================================================
# pa-merge — Personal Assistant — Environment Configuration
# Copy to .env and edit. Never commit .env to version control.
# =============================================================================

# ── Vault ─────────────────────────────────────────────────────────────────────
# Where .md files are stored (calendar/, mail/, threads/, contacts/, attachments/)
PA_VAULT_PATH=~/PersonalAssistantVault

# ── Sync Sources ──────────────────────────────────────────────────────────────
# Comma-separated list of active data sources.
# Available: calendar, mail
#   calendar - Apple Calendar via AppleScript (Calendar.app)
#   mail     - Apple Mail via AppleScript (Mail.app)
PA_SYNC_SOURCES=calendar,mail

# ── Calendar Sync ─────────────────────────────────────────────────────────────
PA_CALENDAR_DAYS_BACK=60
PA_CALENDAR_DAYS_FORWARD=90
# Comma-separated calendar names to sync; leave empty to sync all writable calendars.
# Example: PA_CALENDAR_NAMES=Work,Personal
PA_CALENDAR_NAMES=
PA_CALENDAR_MAX_EVENTS=300
PA_CALENDAR_PER_CAL_TIMEOUT=45
# Set to true to also fetch attendee email addresses (slower AppleScript calls)
PA_CALENDAR_FETCH_ATTENDEES=false

# ── Mail Sync ─────────────────────────────────────────────────────────────────
PA_MAIL_DAYS_BACK=60
# Enumerate attachment names per message (slow on heavy IMAP folders —
# default off; turn on only if vault attachments are needed).
PA_MAIL_FETCH_ATTACHMENT_NAMES=false
PA_MAIL_MAX_MESSAGES=100
PA_MAIL_PER_MBOX_TIMEOUT=45
# Set to false to skip fetching full message body (faster, but body not stored in vault)
PA_MAIL_FETCH_BODY=true
# Set to true to fetch To: recipients per message (slower)
PA_MAIL_FETCH_RECIPIENTS=false
# Set to true to save mail attachments to vault/attachments/ (slower)
PA_MAIL_FETCH_ATTACHMENTS=false
# Where to save mail attachments; default: ~/PersonalAssistantVault/attachments
PA_MAIL_ATTACHMENTS_PATH=~/PersonalAssistantVault/attachments

# ── Sync Behaviour ────────────────────────────────────────────────────────────
# Set to true to re-write existing vault files on each sync
PA_OVERWRITE=false
# Set to true to run sync as part of the scheduled pipeline
PA_SYNC_ON_SCHEDULE=false

# ── MLX Inference ────────────────────────────────────────────────────────────
# Absolute path to a local MLX model directory.
# Example: /Users/you/models/mlx-community/Mistral-7B-Instruct-v0.3-4bit
PA_MLX_MODEL_PATH=
PA_MLX_MAX_TOKENS=1024
PA_MLX_TEMPERATURE=0.3
PA_MLX_CONTEXT_CHARS=12000

# ── Embedding Model (Stage M2 — hybrid search) ────────────────────────────────
# Run `uv run pa list-models` for recommended options.
PA_EMBEDDING_MODEL=
PA_EMBEDDING_MODEL_PATH=
PA_EMBEDDING_SSL_VERIFY=true
PA_HF_TOKEN=

# ── Server ───────────────────────────────────────────────────────────────────
PA_SERVER_HOST=127.0.0.1
PA_SERVER_PORT=8000
PA_LOG_LEVEL=INFO

# ── Scheduler ────────────────────────────────────────────────────────────────
PA_SCHEDULE_ENABLED=false
# Cron expression; default is every day at 9am
PA_SCHEDULE_CRON=0 9 * * *

# ── Classification ───────────────────────────────────────────────────────────
# Path to classify.yaml; leave empty to use default (data/classify.yaml)
PA_CLASSIFY_CONFIG_PATH=
